      "versionNonce": 849569529,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779812561663,
      "link": null,
      "locked": false,
      "text": "Flujo típico:\n1) El usuario pregunta en lenguaje natural.\n2) El supervisor delega en BigQuery Analyst si necesita datos.\n3) La herramienta segura consulta BigQuery.\n4) Business Consultant interpreta los resultados.\n5) El MCP genera informe o snapshot si se solicita.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flujo típico:\n1) El usuario pregunta en lenguaje natural.\n2) El supervisor delega en BigQuery Analyst si necesita datos.\n3) La herramienta segura consulta BigQuery.\n4) Business Consultant interpreta los resultados.\n5) El MCP genera informe o snapshot si se solicita.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 16
    },
    {
      "id": "10a3c52837ba4d45b1f1",
      "type": "text",
      "x": 65,
      "y": 700,
      "width": 900,
      "height": 22.4,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
