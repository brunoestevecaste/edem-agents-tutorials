      "roundness": null,
      "seed": 1242405719,
      "version": 1,
      "versionNonce": 781002307,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779812561663,
      "link": null,
      "locked": false,
      "text": "Controles clave:\n• Solo consultas SELECT\n• Bloqueo de INSERT/UPDATE/DELETE/DROP\n• LIMIT automático\n• maximum_bytes_billed para controlar costes\n• Tablas permitidas del dataset thelook_ecommerce",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Controles clave:\n• Solo consultas SELECT\n• Bloqueo de INSERT/UPDATE/DELETE/DROP\n• LIMIT automático\n• maximum_bytes_billed para controlar costes\n• Tablas permitidas del dataset thelook_ecommerce",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 16
    }
